# ============================================
# CESA Election Portal - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------
# Database (Neon PostgreSQL)
# Get from: https://console.neon.tech
# -----------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@endpoint-pooler.region.aws.neon.tech/dbname?sslmode=require"

# -----------------------------------------------------------------------
# Session Secret — REQUIRED
# Used to sign all JWT tokens (voter + admin sessions).
# Must be at least 32 characters. The app will CRASH on startup if missing.
# Generate a secure value with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -----------------------------------------------------------------------
SESSION_SECRET="REPLACE_ME_WITH_64_CHAR_HEX_STRING"

# -----------------------------------------------------------------------
# Gemini AI (Google)
# Used for OCR verification of student ID photos.
# Get from: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------
GEMINI_API_KEY="your-gemini-api-key-here"

# -----------------------------------------------------------------------
# Cron Job Secret — REQUIRED in production
# Protects the /api/cron/ocr endpoint from public access.
# Must be set in your Vercel environment variables.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then configure Vercel Cron to pass: Authorization: Bearer <CRON_SECRET>
# -----------------------------------------------------------------------
CRON_SECRET="REPLACE_ME_WITH_CRON_SECRET"

# -----------------------------------------------------------------------
# App Config
# -----------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="CESA Election Portal"

# -----------------------------------------------------------------------
# Cloudinary (candidate photo uploads)
# WARNING: NEXT_PUBLIC_ variables are exposed in the browser bundle.
# Ensure your Cloudinary upload preset has SIGNED mode or strict file-type
# restrictions set in the Cloudinary dashboard to prevent abuse.
# -----------------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="your-upload-preset"

# -----------------------------------------------------------------------
# Seed Script Passwords (development only)
# Used only when running: npm run seed
# These are NEVER used at runtime.
# -----------------------------------------------------------------------
SEED_SUPERADMIN_PASSWORD="ChangeMeBeforeSeeding1!"
SEED_ADMIN_PASSWORD="ChangeMeBeforeSeeding1!"
